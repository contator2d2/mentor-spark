# --- App ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:8080
API_URL=http://localhost:3001

# --- Database (PostgreSQL no EasyPanel) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=mentorflow
DB_PASSWORD=changeme_strong_password
DB_NAME=mentorflow
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- JWT ---
JWT_SECRET=replace_with_a_long_random_secret_64_chars_minimum
JWT_EXPIRES_IN=7d

# --- Super Admin (bootstrap inicial) ---
SUPER_ADMIN_EMAIL=admin@mentorflow.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# --- SMTP (envio de emails: senha do prospect, notificações) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxx
SMTP_FROM="MentorFlow <noreply@seudominio.com>"

# --- IA (OpenAI / compatível) ---
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini

# --- CORS ---
CORS_ORIGIN=http://localhost:8080,https://app.seudominio.com
